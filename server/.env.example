# PostgreSQL - use a non-default port (e.g. 5433) to avoid conflict with other instances
DB_HOST=localhost
DB_PORT=5433
DB_NAME=ikomex_finance
DB_USER=ikomex
DB_PASSWORD=changeme

# Session secret (generate a random string)
SESSION_SECRET=changeme-generate-a-long-random-string

# Server
PORT=3000

# First admin user (used by npm run init-db)
# INIT_ADMIN_EMAIL=admin@ikomex.nl
# INIT_ADMIN_PASSWORD=changeme

# Gemini API Key for invoice data extraction (get from Google AI Studio)
# GEMINI_API_KEY=your_api_key_here
